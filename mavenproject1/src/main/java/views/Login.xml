<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.LoginController"
            prefWidth="500" prefHeight="350">

    <VBox alignment="CENTER" spacing="15"
          AnchorPane.topAnchor="40"
          AnchorPane.leftAnchor="80"
          AnchorPane.rightAnchor="80">

        <Label text="Food Delivery Login"
               style="-fx-font-size: 26px; -fx-font-weight: bold;" />

        <TextField fx:id="emailField"
                   promptText="Email"
                   prefWidth="300" />

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       prefWidth="300" />

        <Button text="Login"
                onAction="#login"
                prefWidth="300"
                style="-fx-background-color: #ff7043; -fx-text-fill: white; -fx-font-size: 15px;" />

        <Label fx:id="messageLabel"
               style="-fx-text-fill: red;" />

    </VBox>
</AnchorPane>