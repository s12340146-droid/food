<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.CustomerOrdersController"
           prefWidth="1200"
           prefHeight="750"
           stylesheets="@../styles/customers-module.css">

    <ImageView fitWidth="1200"
               fitHeight="750"
               preserveRatio="false">
        <image>
            <Image url="@../images/background.png"/>
        </image>
    </ImageView>

    <AnchorPane style="-fx-background-color: rgba(0,0,0,0.48);" />

    <BorderPane prefWidth="1200"
                prefHeight="750"
                style="-fx-padding: 24;">

        <top>
            <HBox alignment="CENTER_LEFT"
                  spacing="16"
                  style="
                    -fx-background-color: rgba(255,255,255,0.16);
                    -fx-background-radius: 22;
                    -fx-padding: 18 24 18 24;
                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 15, 0, 0, 4);
                  ">

                <VBox spacing="4">
                    <Label text="My Orders"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;" />

                    <Label text="View your orders and order item details"
                           style="-fx-font-size: 14px; -fx-text-fill: #fbe9e7;" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Back"
                        onAction="#backToDashboard"
                        prefWidth="110"
                        prefHeight="40"
                        style="
                            -fx-background-color: #fff3e0;
                            -fx-text-fill: #e65100;
                            -fx-font-size: 14px;
                            -fx-font-weight: bold;
                            -fx-background-radius: 14;
                            -fx-cursor: hand;
                        " />
            </HBox>
        </top>

        <center>
            <VBox spacing="16"
                  style="
                    -fx-background-color: rgba(255,255,255,0.95);
                    -fx-background-radius: 20;
                    -fx-padding: 20;
                  ">

                <Label text="Order Records"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               promptText="Search by restaurant, status, date, or total"
                               prefWidth="520"
                               prefHeight="40"
                               style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                    <Button text="Search"
                            onAction="#searchOrders"
                            prefWidth="110"
                            prefHeight="40"
                            style="-fx-background-color: #ff7043; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />

                    <Button text="Refresh"
                            onAction="#loadOrders"
                            prefWidth="110"
                            prefHeight="40"
                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                </HBox>

                <TableView fx:id="ordersTable"
                           prefHeight="260"
                           style="-fx-font-size: 13px; -fx-background-radius: 14;">
                    <columns>
                        <TableColumn fx:id="orderIdColumn"
                                     text="Order ID"
                                     prefWidth="110" />

                        <TableColumn fx:id="restaurantColumn"
                                     text="Restaurant"
                                     prefWidth="260" />

                        <TableColumn fx:id="orderDateColumn"
                                     text="Order Date"
                                     prefWidth="210" />

                        <TableColumn fx:id="statusColumn"
                                     text="Status"
                                     prefWidth="170" />

                        <TableColumn fx:id="totalPriceColumn"
                                     text="Total Price"
                                     prefWidth="150" />
                    </columns>
                </TableView>

                <Label text="Selected Order Items"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                <TableView fx:id="orderItemsTable"
                           prefHeight="230"
                           style="-fx-font-size: 13px; -fx-background-radius: 14;">
                    <columns>
                        <TableColumn fx:id="orderItemIdColumn"
                                     text="Order Item ID"
                                     prefWidth="130" />

                        <TableColumn fx:id="itemIdColumn"
                                     text="Item ID"
                                     prefWidth="100" />

                        <TableColumn fx:id="itemNameColumn"
                                     text="Item Name"
                                     prefWidth="260" />

                        <TableColumn fx:id="itemPriceColumn"
                                     text="Price"
                                     prefWidth="120" />

                        <TableColumn fx:id="quantityColumn"
                                     text="Quantity"
                                     prefWidth="120" />

                        <TableColumn fx:id="subtotalColumn"
                                     text="Subtotal"
                                     prefWidth="140" />
                    </columns>
                </TableView>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="Clear"
                            onAction="#clearFields"
                            prefWidth="110"
                            prefHeight="42"
                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                    <Label fx:id="messageLabel"
                           wrapText="true"
                           maxWidth="650"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                </HBox>

            </VBox>
        </center>

    </BorderPane>
</StackPane>