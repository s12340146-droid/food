<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.CustomersModuleController"
           prefWidth="1200"
           prefHeight="750"
           stylesheets="@../styles/customers-module.css">

    <!-- Background Image -->
    <ImageView fitWidth="1200"
               fitHeight="750"
               preserveRatio="false">
        <image>
            <Image url="@../images/background.png"/>
        </image>
    </ImageView>

    <!-- Dark Overlay -->
    <AnchorPane style="-fx-background-color: rgba(0,0,0,0.48);" />

    <BorderPane prefWidth="1200"
                prefHeight="750"
                style="-fx-padding: 22;">

        <!-- Top Bar -->
        <top>
            <HBox alignment="CENTER_LEFT"
                  spacing="16"
                  style="
                    -fx-background-color: rgba(255,255,255,0.15);
                    -fx-background-radius: 22;
                    -fx-padding: 18 24 18 24;
                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 15, 0, 0, 4);
                  ">

                <VBox spacing="4">
                    <Label text="Customers Management"
                           style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;" />

                    <Label text="Manage customers, addresses, locations, carts, and notifications"
                           style="-fx-font-size: 14px; -fx-text-fill: #fbe9e7;" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Back"
                        onAction="#backToDashboard"
                        prefWidth="110"
                        prefHeight="40"
                        style="
                            -fx-background-color: #fff3e0;
                            -fx-text-fill: #e65100;
                            -fx-font-size: 14px;
                            -fx-font-weight: bold;
                            -fx-background-radius: 14;
                            -fx-cursor: hand;
                        " />
            </HBox>
        </top>

        <!-- Center Content -->
        <center>
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     style="
                        -fx-padding: 22 0 0 0;
                        -fx-background-color: transparent;
                     ">

                <!-- Customers Tab -->
                <Tab text="👥 Customers">
                    <BorderPane style="
                        -fx-background-color: rgba(255,255,255,0.94);
                        -fx-background-radius: 20;
                        -fx-padding: 20;
                    ">

                        <top>
                            <VBox spacing="14">

                                <Label text="Customer Records"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <TextField fx:id="searchField"
                                               promptText="Search by username, name, phone, or email"
                                               prefWidth="420"
                                               prefHeight="40"
                                               style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                                    <Button text="Search"
                                            onAction="#searchCustomers"
                                            prefWidth="100"
                                            prefHeight="40"
                                            style="
                                                -fx-background-color: #ff7043;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 12;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Refresh"
                                            onAction="#loadCustomers"
                                            prefWidth="100"
                                            prefHeight="40"
                                            style="
                                                -fx-background-color: #6d4c41;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 12;
                                                -fx-cursor: hand;
                                            " />
                                </HBox>
                            </VBox>
                        </top>

                        <center>
                            <TableView fx:id="customersTable"
                                       prefHeight="345"
                                       style="-fx-font-size: 13px; -fx-background-radius: 14;">

                                <columns>
                                    <TableColumn fx:id="idColumn"
                                                 text="Customer ID"
                                                 prefWidth="100" />

                                    <TableColumn fx:id="usernameColumn"
                                                 text="Username"
                                                 prefWidth="160" />

                                    <TableColumn fx:id="nameColumn"
                                                 text="Name"
                                                 prefWidth="200" />

                                    <TableColumn fx:id="phoneColumn"
                                                 text="Phone"
                                                 prefWidth="160" />

                                    <TableColumn fx:id="emailColumn"
                                                 text="Email"
                                                 prefWidth="270" />

                                    <TableColumn fx:id="passwordColumn"
                                                 text="Password"
                                                 prefWidth="170" />
                                </columns>
                            </TableView>
                        </center>

                        <bottom>
                            <VBox spacing="14"
                                  style="-fx-padding: 15 0 0 0;">

                                <GridPane hgap="14" vgap="12">

                                    <Label text="Username:"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="usernameField"
                                               promptText="Username"
                                               prefWidth="230"
                                               prefHeight="38"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="1"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Name:"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="2"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="nameField"
                                               promptText="Customer name"
                                               prefWidth="230"
                                               prefHeight="38"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="3"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Phone:"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="phoneField"
                                               promptText="Phone number"
                                               prefWidth="230"
                                               prefHeight="38"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="1"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Email:"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="2"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="emailField"
                                               promptText="Email"
                                               prefWidth="230"
                                               prefHeight="38"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="3"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Password:"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <PasswordField fx:id="passwordField"
                                                   promptText="Password"
                                                   prefWidth="230"
                                                   prefHeight="38"
                                                   GridPane.rowIndex="2"
                                                   GridPane.columnIndex="1"
                                                   style="-fx-background-radius: 12;" />
                                </GridPane>

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Button text="Add"
                                            onAction="#addCustomer"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #43a047;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Update"
                                            onAction="#updateCustomer"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #fb8c00;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Delete"
                                            onAction="#deleteCustomer"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #e53935;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Clear"
                                            onAction="#clearFields"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #6d4c41;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Label fx:id="messageLabel"
                                           wrapText="true"
                                           maxWidth="450"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                                </HBox>
                            </VBox>
                        </bottom>
                    </BorderPane>
                </Tab>

                <!-- Addresses Tab -->
                <Tab text="📍 Addresses">
                    <BorderPane style="
                        -fx-background-color: rgba(255,255,255,0.94);
                        -fx-background-radius: 20;
                        -fx-padding: 20;
                    ">

                        <top>
                            <VBox spacing="14">

                                <Label text="Address Records"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <TextField fx:id="addressSearchField"
                                               promptText="Search by customer name, city, street, or building"
                                               prefWidth="460"
                                               prefHeight="40"
                                               style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                                    <Button text="Search"
                                            onAction="#searchAddresses"
                                            prefWidth="100"
                                            prefHeight="40"
                                            style="
                                                -fx-background-color: #ff7043;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 12;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Refresh"
                                            onAction="#loadAddresses"
                                            prefWidth="100"
                                            prefHeight="40"
                                            style="
                                                -fx-background-color: #6d4c41;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 12;
                                                -fx-cursor: hand;
                                            " />
                                </HBox>
                            </VBox>
                        </top>

                        <center>
                            <TableView fx:id="addressesTable"
                                       prefHeight="360"
                                       style="-fx-font-size: 13px; -fx-background-radius: 14;">

                                <columns>
                                    <TableColumn fx:id="addressIdColumn"
                                                 text="Address ID"
                                                 prefWidth="110" />

                                    <TableColumn fx:id="addressCustomerIdColumn"
                                                 text="Customer ID"
                                                 prefWidth="110" />

                                    <TableColumn fx:id="addressCustomerNameColumn"
                                                 text="Customer Name"
                                                 prefWidth="240" />

                                    <TableColumn fx:id="addressLocationIdColumn"
                                                 text="Location ID"
                                                 prefWidth="110" />

                                    <TableColumn fx:id="addressLocationDetailsColumn"
                                                 text="Location Details"
                                                 prefWidth="420" />
                                </columns>
                            </TableView>
                        </center>

                        <bottom>
                            <VBox spacing="14"
                                  style="-fx-padding: 15 0 0 0;">

                                <GridPane hgap="14" vgap="12">

                                    <Label text="Customer:"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <ComboBox fx:id="addressCustomerComboBox"
                                              promptText="Select customer"
                                              prefWidth="330"
                                              prefHeight="38"
                                              GridPane.rowIndex="0"
                                              GridPane.columnIndex="1"
                                              style="-fx-background-radius: 12;" />

                                    <Label text="Location:"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="2"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <ComboBox fx:id="addressLocationComboBox"
                                              promptText="Select location"
                                              prefWidth="380"
                                              prefHeight="38"
                                              GridPane.rowIndex="0"
                                              GridPane.columnIndex="3"
                                              style="-fx-background-radius: 12;" />
                                </GridPane>

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Button text="Add"
                                            onAction="#addAddress"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #43a047;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Update"
                                            onAction="#updateAddress"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #fb8c00;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Delete"
                                            onAction="#deleteAddress"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #e53935;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Clear"
                                            onAction="#clearAddressFields"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #6d4c41;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Label fx:id="addressMessageLabel"
                                           wrapText="true"
                                           maxWidth="450"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                                </HBox>
                            </VBox>
                        </bottom>

                    </BorderPane>
                </Tab>

                <!-- Locations Tab -->
                <Tab text="🌆 Locations">
                    <BorderPane style="
                        -fx-background-color: rgba(255,255,255,0.94);
                        -fx-background-radius: 20;
                        -fx-padding: 20;
                    ">

                        <top>
                            <VBox spacing="14">

                                <Label text="Location Records"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <TextField fx:id="locationSearchField"
                                               promptText="Search by city, street, or building"
                                               prefWidth="420"
                                               prefHeight="40"
                                               style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                                    <Button text="Search"
                                            onAction="#searchLocations"
                                            prefWidth="100"
                                            prefHeight="40"
                                            style="
                                                -fx-background-color: #ff7043;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 12;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Refresh"
                                            onAction="#loadLocations"
                                            prefWidth="100"
                                            prefHeight="40"
                                            style="
                                                -fx-background-color: #6d4c41;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 12;
                                                -fx-cursor: hand;
                                            " />
                                </HBox>
                            </VBox>
                        </top>

                        <center>
                            <TableView fx:id="locationsTable"
                                       prefHeight="380"
                                       style="-fx-font-size: 13px; -fx-background-radius: 14;">

                                <columns>
                                    <TableColumn fx:id="locationIdColumn"
                                                 text="Location ID"
                                                 prefWidth="130" />

                                    <TableColumn fx:id="cityColumn"
                                                 text="City"
                                                 prefWidth="250" />

                                    <TableColumn fx:id="streetColumn"
                                                 text="Street"
                                                 prefWidth="320" />

                                    <TableColumn fx:id="buildingColumn"
                                                 text="Building"
                                                 prefWidth="250" />
                                </columns>
                            </TableView>
                        </center>

                        <bottom>
                            <VBox spacing="14"
                                  style="-fx-padding: 15 0 0 0;">

                                <GridPane hgap="14" vgap="12">

                                    <Label text="City:"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="cityField"
                                               promptText="City"
                                               prefWidth="230"
                                               prefHeight="38"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="1"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Street:"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="2"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="streetField"
                                               promptText="Street"
                                               prefWidth="230"
                                               prefHeight="38"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="3"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Building:"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="buildingField"
                                               promptText="Building"
                                               prefWidth="230"
                                               prefHeight="38"
                                               GridPane.rowIndex="1"
                                               GridPane.columnIndex="1"
                                               style="-fx-background-radius: 12;" />
                                </GridPane>

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Button text="Add"
                                            onAction="#addLocation"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #43a047;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Update"
                                            onAction="#updateLocation"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #fb8c00;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Delete"
                                            onAction="#deleteLocation"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #e53935;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Button text="Clear"
                                            onAction="#clearLocationFields"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="
                                                -fx-background-color: #6d4c41;
                                                -fx-text-fill: white;
                                                -fx-font-weight: bold;
                                                -fx-background-radius: 14;
                                                -fx-cursor: hand;
                                            " />

                                    <Label fx:id="locationMessageLabel"
                                           wrapText="true"
                                           maxWidth="450"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                                </HBox>
                            </VBox>
                        </bottom>

                    </BorderPane>
                </Tab>

                <!-- Carts Tab -->
<Tab text="🛒 Carts">
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent;">

        <VBox spacing="14"
              style="
                -fx-background-color: rgba(255,255,255,0.95);
                -fx-background-radius: 20;
                -fx-padding: 20;
              ">

            <Label text="Cart Records"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="cartSearchField"
                           promptText="Search carts by cart ID, customer ID, or customer name"
                           prefWidth="520"
                           prefHeight="40"
                           style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                <Button text="Search"
                        onAction="#searchCarts"
                        prefWidth="110"
                        prefHeight="40"
                        style="-fx-background-color: #ff7043; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />

                <Button text="Refresh"
                        onAction="#loadCarts"
                        prefWidth="110"
                        prefHeight="40"
                        style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
            </HBox>

            <TableView fx:id="cartsTable"
                       prefHeight="170"
                       style="-fx-font-size: 13px; -fx-background-radius: 14;">
                <columns>
                    <TableColumn fx:id="cartIdColumn"
                                 text="Cart ID"
                                 prefWidth="120" />

                    <TableColumn fx:id="cartCustomerIdColumn"
                                 text="Customer ID"
                                 prefWidth="140" />

                    <TableColumn fx:id="cartCustomerNameColumn"
                                 text="Customer Name"
                                 prefWidth="320" />
                </columns>
            </TableView>

            <GridPane hgap="16" vgap="12">

                <Label text="Customer:"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"
                       style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                <ComboBox fx:id="cartCustomerComboBox"
                          promptText="Select customer"
                          prefWidth="300"
                          prefHeight="38"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="1"
                          style="-fx-background-radius: 12;" />

            </GridPane>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="Add Cart"
                        onAction="#addCart"
                        prefWidth="120"
                        prefHeight="42"
                        style="-fx-background-color: #43a047; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                <Button text="Delete Cart"
                        onAction="#deleteCart"
                        prefWidth="120"
                        prefHeight="42"
                        style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                <Button text="Clear"
                        onAction="#clearCartFields"
                        prefWidth="110"
                        prefHeight="42"
                        style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                <Label fx:id="cartMessageLabel"
                       wrapText="true"
                       maxWidth="520"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;" />
            </HBox>

            <Separator />

            <Label text="Cart Item Records"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="cartItemSearchField"
                           promptText="Search cart items by cart, item, restaurant, or quantity"
                           prefWidth="520"
                           prefHeight="40"
                           style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                <Button text="Search"
                        onAction="#searchCartItems"
                        prefWidth="110"
                        prefHeight="40"
                        style="-fx-background-color: #ff7043; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />

                <Button text="Refresh"
                        onAction="#loadCartItems"
                        prefWidth="110"
                        prefHeight="40"
                        style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
            </HBox>

            <TableView fx:id="cartItemsTable"
                       prefHeight="200"
                       style="-fx-font-size: 13px; -fx-background-radius: 14;">
                <columns>
                    <TableColumn fx:id="cartItemIdColumn"
                                 text="Cart Item ID"
                                 prefWidth="130" />

                    <TableColumn fx:id="cartItemCartIdColumn"
                                 text="Cart ID"
                                 prefWidth="100" />

                    <TableColumn fx:id="cartItemItemIdColumn"
                                 text="Item ID"
                                 prefWidth="100" />

                    <TableColumn fx:id="cartItemNameColumn"
                                 text="Item Name"
                                 prefWidth="220" />

                    <TableColumn fx:id="cartItemRestaurantColumn"
                                 text="Restaurant"
                                 prefWidth="190" />

                    <TableColumn fx:id="cartItemPriceColumn"
                                 text="Price"
                                 prefWidth="110" />

                    <TableColumn fx:id="cartItemQuantityColumn"
                                 text="Quantity"
                                 prefWidth="110" />

                    <TableColumn fx:id="cartItemSubtotalColumn"
                                 text="Subtotal"
                                 prefWidth="130" />
                </columns>
            </TableView>

            <GridPane hgap="16" vgap="12">

                <Label text="Cart:"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"
                       style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                <ComboBox fx:id="cartItemCartComboBox"
                          promptText="Select cart"
                          prefWidth="300"
                          prefHeight="38"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="1"
                          style="-fx-background-radius: 12;" />

                <Label text="Menu Item:"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="2"
                       style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                <ComboBox fx:id="cartItemMenuItemComboBox"
                          promptText="Select menu item"
                          prefWidth="340"
                          prefHeight="38"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="3"
                          style="-fx-background-radius: 12;" />

                <Label text="Quantity:"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"
                       style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                <TextField fx:id="cartItemQuantityField"
                           promptText="Quantity"
                           prefWidth="300"
                           prefHeight="38"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"
                           style="-fx-background-radius: 12;" />

                <Label text="Subtotal:"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="2"
                       style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                <TextField fx:id="cartItemSubtotalField"
                           promptText="Auto calculated"
                           editable="false"
                           prefWidth="340"
                           prefHeight="38"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="3"
                           style="-fx-background-radius: 12;" />

            </GridPane>

            <HBox spacing="12" alignment="CENTER_LEFT">

                <Button text="Calculate"
                        onAction="#calculateCartItemSubtotal"
                        prefWidth="115"
                        prefHeight="42"
                        style="-fx-background-color: #5c6bc0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                <Button text="Add Item"
                        onAction="#addCartItem"
                        prefWidth="115"
                        prefHeight="42"
                        style="-fx-background-color: #43a047; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                <Button text="Update"
                        onAction="#updateCartItem"
                        prefWidth="110"
                        prefHeight="42"
                        style="-fx-background-color: #fb8c00; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                <Button text="Delete"
                        onAction="#deleteCartItem"
                        prefWidth="110"
                        prefHeight="42"
                        style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                <Button text="Clear"
                        onAction="#clearCartItemFields"
                        prefWidth="110"
                        prefHeight="42"
                        style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                <Label fx:id="cartItemMessageLabel"
                       wrapText="true"
                       maxWidth="480"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;" />
            </HBox>

        </VBox>
    </ScrollPane>
</Tab>

                <!-- Notifications Tab -->
<Tab text="🔔 Notifications">
    <BorderPane style="
        -fx-background-color: rgba(255,255,255,0.95);
        -fx-background-radius: 20;
        -fx-padding: 20;
    ">

        <top>
            <VBox spacing="14">
                <Label text="Notification Records"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="notificationSearchField"
                               promptText="Search by notification ID, customer, message, or date"
                               prefWidth="520"
                               prefHeight="40"
                               style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                    <Button text="Search"
                            onAction="#searchNotifications"
                            prefWidth="110"
                            prefHeight="40"
                            style="-fx-background-color: #ff7043; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />

                    <Button text="Refresh"
                            onAction="#loadNotifications"
                            prefWidth="110"
                            prefHeight="40"
                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                </HBox>
            </VBox>
        </top>

        <center>
            <TableView fx:id="notificationsTable"
                       prefHeight="360"
                       style="-fx-font-size: 13px; -fx-background-radius: 14;">
                <columns>
                    <TableColumn fx:id="notificationIdColumn"
                                 text="Notification ID"
                                 prefWidth="140" />

                    <TableColumn fx:id="notificationCustomerIdColumn"
                                 text="Customer ID"
                                 prefWidth="130" />

                    <TableColumn fx:id="notificationCustomerNameColumn"
                                 text="Customer Name"
                                 prefWidth="220" />

                    <TableColumn fx:id="notificationMessageColumn"
                                 text="Message"
                                 prefWidth="430" />

                    <TableColumn fx:id="notificationDateColumn"
                                 text="Date"
                                 prefWidth="190" />
                </columns>
            </TableView>
        </center>

        <bottom>
            <VBox spacing="14" style="-fx-padding: 15 0 0 0;">

                <GridPane hgap="14" vgap="12">

                    <Label text="Customer:"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                    <ComboBox fx:id="notificationCustomerComboBox"
                              promptText="Select customer"
                              prefWidth="300"
                              prefHeight="38"
                              GridPane.rowIndex="0"
                              GridPane.columnIndex="1"
                              style="-fx-background-radius: 12;" />

                    <Label text="Date:"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="2"
                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                    <TextField fx:id="notificationDateField"
                               promptText="Auto NOW() when adding"
                               editable="false"
                               prefWidth="260"
                               prefHeight="38"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="3"
                               style="-fx-background-radius: 12;" />

                    <Label text="Message:"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="0"
                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                    <TextArea fx:id="notificationMessageArea"
                              promptText="Write notification message"
                              prefWidth="700"
                              prefHeight="90"
                              wrapText="true"
                              GridPane.rowIndex="1"
                              GridPane.columnIndex="1"
                              GridPane.columnSpan="3"
                              style="-fx-background-radius: 12;" />
                </GridPane>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="Add"
                            onAction="#addNotification"
                            prefWidth="110"
                            prefHeight="42"
                            style="-fx-background-color: #43a047; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                    <Button text="Update"
                            onAction="#updateNotification"
                            prefWidth="110"
                            prefHeight="42"
                            style="-fx-background-color: #fb8c00; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                    <Button text="Delete"
                            onAction="#deleteNotification"
                            prefWidth="110"
                            prefHeight="42"
                            style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                    <Button text="Clear"
                            onAction="#clearNotificationFields"
                            prefWidth="110"
                            prefHeight="42"
                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                    <Label fx:id="notificationMessageLabel"
                           wrapText="true"
                           maxWidth="520"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>
</Tab>

                

            </TabPane>
        </center>
    </BorderPane>
</StackPane>