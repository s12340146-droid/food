<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.UsersAccountsController"
           prefWidth="1200"
           prefHeight="750"
           stylesheets="@../styles/customers-module.css">

    <ImageView fitWidth="1200"
               fitHeight="750"
               preserveRatio="false">
        <image>
            <Image url="@../images/background.png"/>
        </image>
    </ImageView>

    <AnchorPane style="-fx-background-color: rgba(0,0,0,0.48);" />

    <BorderPane prefWidth="1200"
                prefHeight="750"
                style="-fx-padding: 22;">

        <top>
            <HBox alignment="CENTER_LEFT"
                  spacing="16"
                  style="
                    -fx-background-color: rgba(255,255,255,0.15);
                    -fx-background-radius: 22;
                    -fx-padding: 18 24 18 24;
                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 15, 0, 0, 4);
                  ">

                <VBox spacing="4">
                    <Label text="Users &amp; Accounts Management"
                           style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;" />

                    <Label text="Manage user accounts, roles, and linked customer / manager / driver IDs"
                           style="-fx-font-size: 14px; -fx-text-fill: #fbe9e7;" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Back"
                        onAction="#backToDashboard"
                        prefWidth="110"
                        prefHeight="40"
                        style="
                            -fx-background-color: #fff3e0;
                            -fx-text-fill: #e65100;
                            -fx-font-size: 14px;
                            -fx-font-weight: bold;
                            -fx-background-radius: 14;
                            -fx-cursor: hand;
                        " />
            </HBox>
        </top>

        <center>
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     style="-fx-padding: 22 0 0 0; -fx-background-color: transparent;">

                <!-- User Accounts Tab -->
                <Tab text="👤 User Accounts">
                    <BorderPane style="
                        -fx-background-color: rgba(255,255,255,0.95);
                        -fx-background-radius: 20;
                        -fx-padding: 20;
                    ">

                        <top>
                            <VBox spacing="14">
                                <Label text="User Account Records"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <TextField fx:id="userSearchField"
                                               promptText="Search by username, email, role, or linked IDs"
                                               prefWidth="520"
                                               prefHeight="40"
                                               style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                                    <Button text="Search"
                                            onAction="#searchUsers"
                                            prefWidth="110"
                                            prefHeight="40"
                                            style="-fx-background-color: #ff7043; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />

                                    <Button text="Refresh"
                                            onAction="#loadUsers"
                                            prefWidth="110"
                                            prefHeight="40"
                                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                                </HBox>
                            </VBox>
                        </top>

                        <center>
                            <TableView fx:id="usersTable"
                                       prefHeight="350"
                                       style="-fx-font-size: 13px; -fx-background-radius: 14;">
                                <columns>
                                    <TableColumn fx:id="userIdColumn" text="User ID" prefWidth="80" />
                                    <TableColumn fx:id="usernameColumn" text="Username" prefWidth="150" />
                                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="220" />
                                    <TableColumn fx:id="passwordColumn" text="Password" prefWidth="150" />
                                    <TableColumn fx:id="roleIdColumn" text="Role ID" prefWidth="80" />
                                    <TableColumn fx:id="roleNameColumn" text="Role" prefWidth="130" />
                                    <TableColumn fx:id="customerIdColumn" text="Customer ID" prefWidth="110" />
                                    <TableColumn fx:id="managerIdColumn" text="Manager ID" prefWidth="110" />
                                    <TableColumn fx:id="driverIdColumn" text="Driver ID" prefWidth="100" />
                                </columns>
                            </TableView>
                        </center>

                        <bottom>
                            <VBox spacing="14" style="-fx-padding: 15 0 0 0;">

                                <GridPane hgap="14" vgap="12">
                                    <Label text="Username:"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="usernameField"
                                               promptText="Username"
                                               prefWidth="260"
                                               prefHeight="38"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="1"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Email:"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="2"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="emailField"
                                               promptText="Email"
                                               prefWidth="260"
                                               prefHeight="38"
                                               GridPane.rowIndex="0"
                                               GridPane.columnIndex="3"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Password:"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <PasswordField fx:id="passwordField"
                                                   promptText="Password"
                                                   prefWidth="260"
                                                   prefHeight="38"
                                                   GridPane.rowIndex="1"
                                                   GridPane.columnIndex="1"
                                                   style="-fx-background-radius: 12;" />

                                    <Label text="Role:"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="2"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <ComboBox fx:id="roleComboBox"
                                              promptText="Select role"
                                              prefWidth="260"
                                              prefHeight="38"
                                              GridPane.rowIndex="1"
                                              GridPane.columnIndex="3"
                                              style="-fx-background-radius: 12;" />

                                    <Label text="Customer ID:"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="customerIdField"
                                               promptText="Optional"
                                               prefWidth="260"
                                               prefHeight="38"
                                               GridPane.rowIndex="2"
                                               GridPane.columnIndex="1"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Manager ID:"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="2"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="managerIdField"
                                               promptText="Optional"
                                               prefWidth="260"
                                               prefHeight="38"
                                               GridPane.rowIndex="2"
                                               GridPane.columnIndex="3"
                                               style="-fx-background-radius: 12;" />

                                    <Label text="Driver ID:"
                                           GridPane.rowIndex="3"
                                           GridPane.columnIndex="0"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="driverIdField"
                                               promptText="Optional"
                                               prefWidth="260"
                                               prefHeight="38"
                                               GridPane.rowIndex="3"
                                               GridPane.columnIndex="1"
                                               style="-fx-background-radius: 12;" />
                                </GridPane>

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Button text="Add"
                                            onAction="#addUser"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="-fx-background-color: #43a047; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                                    <Button text="Update"
                                            onAction="#updateUser"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="-fx-background-color: #fb8c00; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                                    <Button text="Delete"
                                            onAction="#deleteUser"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                                    <Button text="Clear"
                                            onAction="#clearUserFields"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                                    <Label fx:id="userMessageLabel"
                                           wrapText="true"
                                           maxWidth="500"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                                </HBox>

                            </VBox>
                        </bottom>
                    </BorderPane>
                </Tab>

                <!-- Roles Tab -->
                <Tab text="🛡 Roles">
                    <BorderPane style="
                        -fx-background-color: rgba(255,255,255,0.95);
                        -fx-background-radius: 20;
                        -fx-padding: 20;
                    ">

                        <top>
                            <VBox spacing="14">
                                <Label text="Role Records"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <TextField fx:id="roleSearchField"
                                               promptText="Search by role name"
                                               prefWidth="420"
                                               prefHeight="40"
                                               style="-fx-background-radius: 12; -fx-font-size: 14px;" />

                                    <Button text="Search"
                                            onAction="#searchRoles"
                                            prefWidth="110"
                                            prefHeight="40"
                                            style="-fx-background-color: #ff7043; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />

                                    <Button text="Refresh"
                                            onAction="#loadRoles"
                                            prefWidth="110"
                                            prefHeight="40"
                                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" />
                                </HBox>
                            </VBox>
                        </top>

                        <center>
                            <TableView fx:id="rolesTable"
                                       prefHeight="400"
                                       style="-fx-font-size: 13px; -fx-background-radius: 14;">
                                <columns>
                                    <TableColumn fx:id="roleTableIdColumn" text="Role ID" prefWidth="140" />
                                    <TableColumn fx:id="roleTableNameColumn" text="Role Name" prefWidth="360" />
                                </columns>
                            </TableView>
                        </center>

                        <bottom>
                            <VBox spacing="14" style="-fx-padding: 15 0 0 0;">

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label text="Role Name:"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3e2723;" />

                                    <TextField fx:id="roleNameField"
                                               promptText="Example: Admin"
                                               prefWidth="300"
                                               prefHeight="38"
                                               style="-fx-background-radius: 12;" />
                                </HBox>

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Button text="Add"
                                            onAction="#addRole"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="-fx-background-color: #43a047; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                                    <Button text="Update"
                                            onAction="#updateRole"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="-fx-background-color: #fb8c00; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                                    <Button text="Delete"
                                            onAction="#deleteRole"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                                    <Button text="Clear"
                                            onAction="#clearRoleFields"
                                            prefWidth="110"
                                            prefHeight="42"
                                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand;" />

                                    <Label fx:id="roleMessageLabel"
                                           wrapText="true"
                                           maxWidth="500"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                                </HBox>
                            </VBox>
                        </bottom>
                    </BorderPane>
                </Tab>

            </TabPane>
        </center>
    </BorderPane>
</StackPane>