<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.RegisterController"
           prefWidth="1200"
           prefHeight="750">

    <ImageView fitWidth="1200"
               fitHeight="750"
               preserveRatio="false">
        <image>
            <Image url="@../images/background.png"/>
        </image>
    </ImageView>

    <HBox alignment="CENTER_RIGHT"
          prefWidth="1200"
          prefHeight="750"
          style="-fx-padding: 0 120 0 0;">

        <VBox alignment="CENTER"
              spacing="12"
              prefWidth="520"
              maxWidth="520"
              style="
                -fx-background-color: rgba(255,255,255,0.94);
                -fx-background-radius: 28;
                -fx-padding: 34;
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 24, 0, 0, 10);
              ">

            <Label text="Create Account"
                   style="
                    -fx-font-size: 34px;
                    -fx-font-weight: bold;
                    -fx-text-fill: #3e2723;
                   " />

            <Label text="Join our Food Delivery System"
                   style="
                    -fx-font-size: 16px;
                    -fx-text-fill: #6d4c41;
                   " />

            <TextField fx:id="usernameField"
                       promptText="Username"
                       prefWidth="380"
                       prefHeight="46"
                       style="
                        -fx-background-radius: 16;
                        -fx-border-radius: 16;
                        -fx-font-size: 15px;
                        -fx-padding: 0 15 0 15;
                       " />

            <TextField fx:id="nameField"
                       promptText="Full Name"
                       prefWidth="380"
                       prefHeight="46"
                       style="
                        -fx-background-radius: 16;
                        -fx-border-radius: 16;
                        -fx-font-size: 15px;
                        -fx-padding: 0 15 0 15;
                       " />

            <TextField fx:id="phoneField"
                       promptText="Phone Number"
                       prefWidth="380"
                       prefHeight="46"
                       style="
                        -fx-background-radius: 16;
                        -fx-border-radius: 16;
                        -fx-font-size: 15px;
                        -fx-padding: 0 15 0 15;
                       " />

            <TextField fx:id="emailField"
                       promptText="Email"
                       prefWidth="380"
                       prefHeight="46"
                       style="
                        -fx-background-radius: 16;
                        -fx-border-radius: 16;
                        -fx-font-size: 15px;
                        -fx-padding: 0 15 0 15;
                       " />

            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           prefWidth="380"
                           prefHeight="46"
                           style="
                            -fx-background-radius: 16;
                            -fx-border-radius: 16;
                            -fx-font-size: 15px;
                            -fx-padding: 0 15 0 15;
                           " />

            <PasswordField fx:id="confirmPasswordField"
                           promptText="Confirm Password"
                           prefWidth="380"
                           prefHeight="46"
                           style="
                            -fx-background-radius: 16;
                            -fx-border-radius: 16;
                            -fx-font-size: 15px;
                            -fx-padding: 0 15 0 15;
                           " />

            <Button text="Register"
                    onAction="#register"
                    prefWidth="380"
                    prefHeight="48"
                    style="
                        -fx-background-color: #ff7043;
                        -fx-text-fill: white;
                        -fx-font-size: 17px;
                        -fx-font-weight: bold;
                        -fx-background-radius: 16;
                        -fx-cursor: hand;
                    " />

            <Button text="Back to Login"
                    onAction="#goToLogin"
                    prefWidth="380"
                    prefHeight="44"
                    style="
                        -fx-background-color: #fff3e0;
                        -fx-text-fill: #e65100;
                        -fx-font-size: 15px;
                        -fx-font-weight: bold;
                        -fx-background-radius: 16;
                        -fx-cursor: hand;
                    " />

            <Label fx:id="messageLabel"
                   wrapText="true"
                   maxWidth="380"
                   style="
                    -fx-text-fill: red;
                    -fx-font-size: 14px;
                   " />

        </VBox>
    </HBox>

</StackPane>